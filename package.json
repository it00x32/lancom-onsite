{
  "name": "onsite",
  "version": "0.11.2",
  "description": "OnSite – lokales SNMP-Dashboard",
  "main": "server.js",
  "bin": {
    "onsite": "server.js"
  },
  "pkg": {
    "assets": [
      "index.html",
      "app.js",
      "styles.css"
    ],
    "targets": [
      "node22-linux-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "build": "esbuild ui/main.js --bundle --format=iife --outfile=app.js --target=es2020",
    "watch": "esbuild ui/main.js --bundle --format=iife --outfile=app.js --target=es2020 --watch",
    "start": "node server.js",
    "dev": "npm run build && node server.js",
    "freeradius:up": "docker compose -f docker-compose.freeradius.yml up -d",
    "freeradius:down": "docker compose -f docker-compose.freeradius.yml down"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/it00x32/lancom-onsite.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/it00x32/lancom-onsite/issues"
  },
  "homepage": "https://github.com/it00x32/lancom-onsite#readme",
  "dependencies": {
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "net-snmp": "^3.26.1",
    "nodemailer": "^8.0.2",
    "radius": "^1.1.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
